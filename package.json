{
  "name": "sphera",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=20 <21",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "pnpm lint:code-fix && pnpm lint:format-fix",
    "lint:code-fix": "eslint . --fix",
    "lint:format-fix": "prettier . --write",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky install",
    "commit": "cz",
    "pre-commit": "pnpm lint && pnpm type-check && pnpm build"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-customizable"
    },
    "cz-customizable": {
      "config": "cz-config.js"
    }
  },
  "dependencies": {
    "clsx": "2.1.1",
    "echarts": "^6.0.0",
    "mobx": "6.15.0",
    "mobx-react-lite": "4.1.1",
    "next": "16.1.3",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "zod": "4.3.5"
  },
  "devDependencies": {
    "@types/node": "20.19.30",
    "@types/react": "19.2.8",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.53.0",
    "@typescript-eslint/parser": "8.53.0",
    "commitizen": "^4.3.1",
    "cz-customizable": "^7.0.0",
    "eslint": "9.39.2",
    "eslint-config-next": "16.1.3",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "prettier": "3.8.0",
    "sass": "1.97.2",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix"
    ],
    "*.{ts,tsx,js,jsx,mjs,cjs,scss,md,json}": [
      "prettier --write"
    ]
  }
}
